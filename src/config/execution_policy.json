{
  "version": 1,
  "timezone": "UTC",
  "schedules": {
    "quantum_cache_fill_monthly": {
      "task_name": "QuantumCacheFill_Monthly",
      "day_of_month": 1,
      "hour": 1,
      "minute": 0
    },
    "shors_monthly_benchmark": {
      "task_name": "ShorsMonthlyBench",
      "day_of_month": 1,
      "hour": 2,
      "minute": 0
    },
    "vqe_monthly_benchmark": {
      "task_name": "VQEMonthlyBench",
      "day_of_month": 15,
      "hour": 3,
      "minute": 0
    },
    "QuantumCacheDepletionGuard_Daily": {
      "policy_id": "QuantumCacheDepletionGuard_Daily",
      "task_name": "QuantumCacheDepletionGuard_Daily",
      "schedule": "daily",
      "time_utc": "06:00",
      "command": "C:\\G\\python.exe tools\\cache_depletion_guard.py",
      "depletion_threshold_pct": 0.25,
      "description": "Daily cache depletion monitor. Triggers early QuantumCacheFill_Monthly if cache < 25% capacity."
    },
    "PolicyComplianceAudit_Daily": {
      "policy_id": "PolicyComplianceAudit_Daily",
      "task_name": "PolicyComplianceAudit_Daily",
      "schedule": "daily",
      "time_utc": "07:00",
      "command": "C:\\G\\python.exe tools\\audit_policy.py",
      "description": "Daily compliance audit of execution_policy.json: schema, linkage, QPU cap coverage, and backup drift checks."
    },
    "QuantumBackendAvailabilityMonitor_Daily": {
      "policy_id": "QuantumBackendAvailabilityMonitor_Daily",
      "task_name": "QuantumBackendAvailabilityMonitor_Daily",
      "schedule": "daily",
      "time_utc": "08:00",
      "command": "C:\\G\\python.exe tools\\backend_availability_monitor.py",
      "description": "Daily IBM Quantum + Amazon Braket availability monitor."
    }
  },
  "qpu_caps_seconds": {
    "quantum_cache_fill_monthly": 180,
    "shors_monthly_benchmark": 300,
    "vqe_monthly_benchmark": 600,
    "QuantumCacheDepletionGuard_Daily": 30,
    "PolicyComplianceAudit_Daily": 30,
    "QuantumBackendAvailabilityMonitor_Daily": 30
  }
}
